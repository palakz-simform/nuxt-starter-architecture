{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run dev:*)",
      "Bash(npm run build)",
      "Bash(npm run generate)",
      "Bash(npm run preview)",
      "Bash(npm run lint:*)",
      "Bash(npm run format)",
      "Bash(npm run typecheck)",
      "Bash(npm test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx nuxi:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/eslint-fix.sh\""
          }
        ]
      }
    ]
  }
}
