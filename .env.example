# Copy to `.env` and fill in. Never commit `.env`.
# Client-exposed values map to runtimeConfig.public in nuxt.config.ts.
NUXT_PUBLIC_APP_NAME="Expense Tracker"

# Server-only secrets map to top-level runtimeConfig (no NUXT_PUBLIC_ prefix).
# Example for a future Claude-powered feature:
# NUXT_ANTHROPIC_API_KEY=""
